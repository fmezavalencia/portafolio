---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, PERSONAL_INFO } from '../consts';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Contacto | ${SITE_TITLE}`} description="Contacta a Anthony Meza" />
	</head>
	<body>
		<Header />
		<main>
			<section class="contact-hero">
				<h1>Contacto</h1>
				<p class="contact-subtitle">¿Trabajamos juntos?</p>
			</section>

			<section class="contact-content">
				<div class="contact-info">
					<h2>Información de Contacto</h2>
					<p>
						Estoy disponible para oportunidades laborales, proyectos freelance
						o cualquier consulta sobre mi trabajo. No dudes en contactarme.
					</p>

					<div class="contact-details">
						<div class="contact-item">
							<span class="contact-icon">📧</span>
							<div>
								<span class="contact-label">Email</span>
								<a href="mailto:{PERSONAL_INFO.email}">{PERSONAL_INFO.email}</a>
							</div>
						</div>
						<div class="contact-item">
							<span class="contact-icon">📱</span>
							<div>
								<span class="contact-label">Teléfono</span>
								<a href="tel:{PERSONAL_INFO.phone}">{PERSONAL_INFO.phone}</a>
							</div>
						</div>
						<div class="contact-item">
							<span class="contact-icon">📍</span>
							<div>
								<span class="contact-label">Ubicación</span>
								<span>{PERSONAL_INFO.location}</span>
							</div>
						</div>
					</div>

					<div class="social-links">
						<a href="https://github.com/" target="_blank" class="social-link">
							<svg viewBox="0 0 16 16" width="24" height="24" fill="currentColor">
								<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
							</svg>
							<span>GitHub</span>
						</a>
						<a href="https://linkedin.com/" target="_blank" class="social-link">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
								<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path>
							</svg>
							<span>LinkedIn</span>
						</a>
					</div>
				</div>

				<div class="contact-form">
					<h2>Envíame un mensaje</h2>
					<form action="https://formsubmit.co/fmezavalencia@gmail.com" method="POST">
						<input type="text" name="name" placeholder="Tu nombre" required />
						<input type="email" name="email" placeholder="Tu email" required />
						<input type="text" name="subject" placeholder="Asunto" required />
						<textarea name="message" rows="5" placeholder="Tu mensaje..." required></textarea>
						<button type="submit" class="btn">Enviar Mensaje</button>
					</form>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.contact-hero {
		padding: 3rem 0;
		text-align: center;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 3rem;
	}
	.contact-hero h1 {
		font-size: 2.5rem;
		color: rgb(var(--black));
		margin-bottom: 0.5rem;
	}
	.contact-subtitle {
		font-size: 1.2rem;
		color: rgb(var(--gray));
	}

	.contact-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		margin-bottom: 3rem;
	}

	.contact-info h2 {
		color: rgb(var(--black));
		margin-bottom: 1rem;
	}
	.contact-info > p {
		color: rgb(var(--gray-dark));
		line-height: 1.7;
		margin-bottom: 2rem;
	}

	.contact-details {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.contact-item {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.contact-icon {
		font-size: 1.5rem;
	}
	.contact-item div {
		display: flex;
		flex-direction: column;
	}
	.contact-label {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		margin-bottom: 0.2rem;
	}
	.contact-item a, .contact-item span {
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.contact-item a:hover {
		color: var(--accent);
	}

	.social-links {
		display: flex;
		gap: 1rem;
	}
	.social-link {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.8rem 1.2rem;
		background: white;
		border-radius: var(--border-radius);
		box-shadow: var(--box-shadow);
		color: rgb(var(--gray-dark));
		text-decoration: none;
		transition: var(--transition);
	}
	.social-link:hover {
		box-shadow: var(--box-shadow-lg);
		color: var(--accent);
	}

	.contact-form {
		background: white;
		border-radius: var(--border-radius);
		box-shadow: var(--box-shadow);
		padding: 2rem;
	}
	.contact-form h2 {
		color: rgb(var(--black));
		margin-bottom: 1.5rem;
	}

	.contact-form form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.contact-form input,
	.contact-form textarea {
		padding: 0.8rem 1rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		font-size: 1rem;
		font-family: inherit;
		transition: var(--transition);
	}
	.contact-form input:focus,
	.contact-form textarea:focus {
		outline: none;
		border-color: var(--accent);
		box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
	}

	.contact-form textarea {
		resize: vertical;
		min-height: 120px;
	}

	.contact-form .btn {
		width: 100%;
		text-align: center;
		cursor: pointer;
		border: none;
		font-size: 1rem;
	}

	@media (max-width: 720px) {
		.contact-content {
			grid-template-columns: 1fr;
		}
	}
</style>
