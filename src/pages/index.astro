---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, PERSONAL_INFO, SKILLS } from '../consts';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-content">
					<p class="hero-greeting">Hola, soy</p>
					<h1 class="hero-name">{PERSONAL_INFO.name}</h1>
					<h2 class="hero-title">{PERSONAL_INFO.title}</h2>
					<p class="hero-description">
						Técnico en Desarrollo de Software con experiencia en desarrollo de aplicaciones web,
						sistemas de gestión de información y frameworks modernos. Apasionado por crear soluciones
						eficientes y escalables.
					</p>
					<div class="hero-buttons">
						<a href="portafolio/projects" class="btn">Ver Proyectos</a>
						<a href="portafolio/contact" class="btn btn-outline">Contactar</a>
					</div>
				</div>
				<div class="hero-skills">
					<div class="skill-tags">
						{SKILLS.languages.map((skill) => (
							<span class="tag">{skill}</span>
						))}
						{SKILLS.frontend.slice(0, 3).map((skill) => (
							<span class="tag">{skill}</span>
						))}
					</div>
				</div>
			</section>

			<section class="quick-view">
				<div class="quick-card">
					<div class="quick-icon">💼</div>
					<h3>Experiencia</h3>
					<p>Prácticas preprofesionales en desarrollo web y sistemas de gestión</p>
					<a href="portafolio/experience">Ver más →</a>
				</div>
				<div class="quick-card">
					<div class="quick-icon">🛠️</div>
					<h3>Habilidades</h3>
					<p>PHP, JavaScript, Python, React, Laravel, Flutter y más</p>
					<a href="portafolio/skills">Ver más →</a>
				</div>
				<div class="quick-card">
					<div class="quick-icon">🎯</div>
					<h3>Proyectos</h3>
					<p>Sistemas web, aplicaciones móviles y dashboards de análisis</p>
					<a href="portafolio/projects">Ver más →</a>
				</div>
			</section>

			<section class="highlights">
				<h2>¿Por qué contratarme?</h2>
				<div class="highlights-grid">
					<div class="highlight-item">
						<h4>🎯 Enfoque en Resultados</h4>
						<p>Desarrollo soluciones que resuelven problemas reales y generan valor para las organizaciones.</p>
					</div>
					<div class="highlight-item">
						<h4>📚 Aprendizaje Continuo</h4>
						<p>Me mantengo actualizado con las últimas tecnologías y mejores prácticas del desarrollo.</p>
					</div>
					<div class="highlight-item">
						<h4>🤝 Trabajo en Equipo</h4>
						<p>Experiencia colaborando en equipos multidisciplinarios para alcanzar objetivos comunes.</p>
					</div>
					<div class="highlight-item">
						<h4>⚡ Resolución de Problemas</h4>
						<p>Capacidad para analizar, diseñar e implementar soluciones técnicas eficientes.</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 4rem 0;
		text-align: center;
	}
	.hero-content {
		max-width: 700px;
		margin: 0 auto;
	}
	.hero-greeting {
		font-size: 1.2rem;
		color: var(--accent);
		font-weight: 600;
		margin-bottom: 0.5rem;
	}
	.hero-name {
		font-size: 3.5rem;
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: 0.5rem;
		line-height: 1.1;
	}
	.hero-title {
		font-size: 1.5rem;
		color: var(--accent);
		font-weight: 500;
		margin-bottom: 1.5rem;
	}
	.hero-description {
		font-size: 1.1rem;
		color: var(--text-secondary);
		line-height: 1.8;
		margin-bottom: 2rem;
	}
	.hero-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}
	.hero-skills {
		margin-top: 3rem;
	}
	.skill-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		justify-content: center;
	}

	.quick-view {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.5rem;
		margin: 4rem 0;
	}
	.quick-card {
		background: var(--bg-card);
		border-radius: var(--border-radius);
		box-shadow: var(--box-shadow);
		padding: 2rem;
		text-align: center;
		transition: var(--transition);
	}
	.quick-card:hover {
		box-shadow: var(--box-shadow-lg);
		transform: translateY(-4px);
	}
	.quick-icon {
		font-size: 2.5rem;
		margin-bottom: 1rem;
	}
	.quick-card h3 {
		color: var(--text-primary);
		margin-bottom: 0.5rem;
	}
	.quick-card p {
		color: var(--text-secondary);
		margin-bottom: 1rem;
		font-size: 0.95rem;
	}
	.quick-card a {
		color: var(--accent);
		font-weight: 600;
		text-decoration: none;
	}
	.quick-card a:hover {
		text-decoration: underline;
	}

	.highlights {
		margin: 4rem 0;
	}
	.highlights h2 {
		text-align: center;
		margin-bottom: 2rem;
		color: var(--text-primary);
	}
	.highlights-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1.5rem;
	}
	.highlight-item {
		padding: 1.5rem;
		background: var(--bg-card);
		border-radius: var(--border-radius);
		box-shadow: var(--box-shadow);
	}
	.highlight-item h4 {
		color: var(--text-primary);
		margin-bottom: 0.5rem;
		font-size: 1.1rem;
	}
	.highlight-item p {
		color: var(--text-secondary);
		font-size: 0.95rem;
		margin: 0;
	}

	@media (max-width: 720px) {
		.hero-name {
			font-size: 2.5rem;
		}
		.hero-title {
			font-size: 1.2rem;
		}
	}
</style>
