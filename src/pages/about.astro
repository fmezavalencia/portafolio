---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, PERSONAL_INFO, EDUCATION, CERTIFICATIONS, SOFT_SKILLS } from '../consts';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Sobre Mí | ${SITE_TITLE}`} description="Conoce más sobre Flavio Anthony Meza Valencia" />
	</head>
	<body>
		<Header />
		<main>
			<section class="about-hero">
				<div class="about-intro">
					<h1>Sobre Mí</h1>
					<p class="about-subtitle">Técnico en Desarrollo de Software</p>
				</div>
			</section>

			<section class="about-content">
				<div class="about-text">
					<h2>Perfil Profesional</h2>
					<p>
						Técnico en Desarrollo de Software, con experiencia en prácticas preprofesionales en
						instituciones y empresas. Experiencia en desarrollo de aplicaciones web y sistemas de
						gestión de información, con conocimientos en programación, bases de datos y frameworks modernos.
					</p>
					<p>
						Apasionado por crear soluciones tecnológicas que resuelvan problemas reales. Me destaco
						por mi capacidad de aprendizaje rápido, trabajo en equipo y compromiso con la calidad
						del código.
					</p>
				</div>

				<div class="about-sidebar">
					<div class="info-card">
						<h3>Datos de Contacto</h3>
						<div class="info-item">
							<span class="info-label">Email:</span>
							<a href="mailto:{PERSONAL_INFO.email}">{PERSONAL_INFO.email}</a>
						</div>
					<div class="info-item">
						<span class="info-label">Ubicación:</span>
							<span>{PERSONAL_INFO.location}</span>
						</div>
						<div class="info-item">
							<span class="info-label">Idioma:</span>
							<span>Inglés - Nivel B1 (Intermedio)</span>
						</div>
					</div>
				</div>
			</section>

			<section class="education">
				<h2>Educación</h2>
				<div class="education-list">
					{EDUCATION.map((edu) => (
						<div class="education-item">
							<div class="education-header">
								<h3>{edu.degree}</h3>
								<span class="education-period">{edu.period}</span>
							</div>
							<p class="education-institution">{edu.institution}</p>
							<span class="education-status">{edu.status}</span>
						</div>
					))}
				</div>
			</section>

			<section class="certifications">
				<h2>Certificaciones</h2>
				<div class="cert-list">
					{CERTIFICATIONS.map((cert) => (
						<div class="cert-item">
							<span class="cert-icon">🎓</span>
							<span>{cert}</span>
						</div>
					))}
				</div>
			</section>

			<section class="soft-skills">
				<h2>Competencias Personales</h2>
				<div class="soft-skills-grid">
					{SOFT_SKILLS.map((skill) => (
						<div class="soft-skill-item">
							<span class="soft-skill-icon">✓</span>
							<span>{skill}</span>
						</div>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-hero {
		padding: 3rem 0;
		text-align: center;
		border-bottom: 1px solid var(--border-color);
		margin-bottom: 3rem;
	}
	.about-intro h1 {
		font-size: 2.5rem;
		color: var(--text-primary);
		margin-bottom: 0.5rem;
	}
	.about-subtitle {
		font-size: 1.2rem;
		color: var(--accent);
		font-weight: 500;
	}

	.about-content {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 3rem;
		margin-bottom: 4rem;
	}
	.about-text h2 {
		color: var(--text-primary);
		margin-bottom: 1rem;
	}
	.about-text p {
		color: var(--text-body);
		line-height: 1.8;
		margin-bottom: 1.5rem;
	}

	.info-card {
		background: var(--bg-card);
		border-radius: var(--border-radius);
		box-shadow: var(--box-shadow);
		padding: 1.5rem;
	}
	.info-card h3 {
		color: var(--text-primary);
		font-size: 1.2rem;
		margin-bottom: 1rem;
		padding-bottom: 0.5rem;
		border-bottom: 2px solid var(--accent);
	}
	.info-item {
		margin-bottom: 0.8rem;
		display: flex;
		flex-direction: column;
	}
	.info-label {
		font-size: 0.85rem;
		color: var(--text-secondary);
		margin-bottom: 0.2rem;
	}
	.info-item a, .info-item span {
		color: var(--text-body);
		font-size: 0.95rem;
	}

	.education {
		margin-bottom: 4rem;
	}
	.education h2 {
		color: var(--text-primary);
		margin-bottom: 1.5rem;
	}
	.education-item {
		background: var(--bg-card);
		border-radius: var(--border-radius);
		box-shadow: var(--box-shadow);
		padding: 1.5rem;
		margin-bottom: 1rem;
		border-left: 4px solid var(--accent);
	}
	.education-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.education-header h3 {
		color: var(--text-primary);
		font-size: 1.2rem;
		margin: 0;
	}
	.education-period {
		color: var(--accent);
		font-weight: 500;
		font-size: 0.9rem;
	}
	.education-institution {
		color: var(--text-secondary);
		margin: 0.5rem 0;
	}
	.education-status {
		display: inline-block;
		padding: 0.2rem 0.8rem;
		background: rgba(34, 197, 94, 0.1);
		color: #16a34a;
		border-radius: 9999px;
		font-size: 0.85rem;
		font-weight: 500;
	}

	.certifications {
		margin-bottom: 4rem;
	}
	.certifications h2 {
		color: var(--text-primary);
		margin-bottom: 1.5rem;
	}
	.cert-list {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1rem;
	}
	.cert-item {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		background: var(--bg-card);
		border-radius: var(--border-radius);
		box-shadow: var(--box-shadow);
		padding: 1rem 1.5rem;
	}
	.cert-icon {
		font-size: 1.5rem;
	}

	.soft-skills h2 {
		color: var(--text-primary);
		margin-bottom: 1.5rem;
	}
	.soft-skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 1rem;
	}
	.soft-skill-item {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		background: var(--bg-card);
		border-radius: var(--border-radius);
		box-shadow: var(--box-shadow);
		padding: 1rem 1.5rem;
	}
	.soft-skill-icon {
		color: #16a34a;
		font-weight: bold;
		font-size: 1.2rem;
	}

	@media (max-width: 720px) {
		.about-content {
			grid-template-columns: 1fr;
		}
		.education-header {
			flex-direction: column;
		}
	}
</style>
